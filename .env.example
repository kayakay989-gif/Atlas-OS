# Atlas Sales OS — Environment Variables
# Copy to .env.local for local development

# ─── App ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Trigger.dev (Worker) ───────────────────────────────
TRIGGER_SECRET_KEY=tr_dev_your-key

# ─── AI (M2+) ───────────────────────────────────────────
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# ─── Email (M4+) ────────────────────────────────────────
# RESEND_API_KEY=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ─── Booking (Calendly) ─────────────────────────────────────────────────
NEXT_PUBLIC_BOOKING_URL=https://calendly.com/essa-qasim/30min

# ─── Feature Flags (ADR-0012) ───────────────────────────
# Safe defaults are false — enable modules as milestones complete
# FF_DISCOVERY_PIPELINE=true
# FF_OUTREACH_GENERATION=true
# FF_EMAIL_SENDING=true
# FF_CAMPAIGN_EXECUTION=true
# FF_MEETING_BOOKING=true
# FF_CONVERSION_PIPELINE=true
# FF_LEARNING_OPTIMIZATION=true
# FF_OPS_MONITORING=true
# FF_CRM_MODULE=false
# FF_AI_AGENTS=false

# ─── Web Extraction (M2+) ───────────────────────────────
# FIRECRAWL_API_KEY=
